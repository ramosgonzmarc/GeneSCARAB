plants <- read.csv(paste0("../../pathways_", "plants", ".txt"), sep = "\t", header = T)$x
plants <- sapply(strsplit(plants, "ko"), function(x) x[[2]])
animals <- read.csv(paste0("../../pathways_", "animals", ".txt"), sep = "\t", header = T)$x
animals <- sapply(strsplit(animals, "ko"), function(x) x[[2]])
fungi <- read.csv(paste0("../../pathways_", "fungi", ".txt"), sep = "\t", header = T)$x
fungi <- sapply(strsplit(fungi, "ko"), function(x) x[[2]])
protists <- read.csv(paste0("../../pathways_", "protists", ".txt"), sep = "\t", header = T)$x
protists <- sapply(strsplit(protists, "ko"), function(x) x[[2]])
bacteria <- read.csv(paste0("../../pathways_", "bacteria", ".txt"), sep = "\t", header = T)$x
bacteria <- sapply(strsplit(bacteria, "ko"), function(x) x[[2]])
archaea <- read.csv(paste0("../../pathways_", "archaea", ".txt"), sep = "\t", header = T)$x
archaea <- sapply(strsplit(archaea, "ko"), function(x) x[[2]])
kegg_pathways_per_species <- list(bacteria = bacteria, archaea = archaea,
protists = protists, fungi = fungi,
plants = plants, animals = animals)
usethis::use_data(kegg_pathways_per_species, internal = TRUE)
